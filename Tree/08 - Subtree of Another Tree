## Final C# Code

```csharp
public class Solution {    
    List<string> tree;
    List<string> subtree;
    public bool IsSubtree(TreeNode root, TreeNode subRoot) {
        tree = new List<string>();
        subtree = new List<string>();
        Preorder(root,tree);
        Preorder(subRoot,subtree);
        string treeString = String.Join(",",tree);
        string subtreeString = String.Join(",",subtree);
        Console.WriteLine($"{treeString},sub {subtreeString}");
        return treeString.Contains(subtreeString);
    }

    public void Preorder(TreeNode root, List<string> l){
        l.Add("$" + root.val);
        if(root.left != null)
            Preorder(root.left, l);
        else{
             l.Add("#");
        }
        if(root.right != null)
            Preorder(root.right, l);
        else{
             l.Add("#");
        }
    }
}

