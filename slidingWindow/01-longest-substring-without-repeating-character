public int LengthOfLongestSubstring(string s) {
        var st = 0;
        var e = 0;
        var l = 1;
        if(s.Length == 0) return 0;
         Dictionary<int, int> dic = new Dictionary<int, int>();
        dic[s[e]] = e;
        e++;
       
        while( e < s.Length)
        {
            if(dic.ContainsKey(s[e]))
            {
               var indOfSeen = dic[s[e]];
               if(indOfSeen >= st)
               {
                    l = Math.Max(e - st, l); // find the max length till now
                    st = dic[s[e]] + 1; // start will update if it is present
                    
               }
               else
               {
                    l = Math.Max((e - st) + 1, l);                       
               }                
            }
            else
            {
                 l = Math.Max((e - st) + 1, l);    
            }
            dic[s[e]] = e;
            e++;
        }
        return l;
    }
    
public int LengthOfLongestSubstring(string s) {
        var l = 0;
        var maxLen = 1;
        if(s.Length == 0) return 0;
        Dictionary<char, int> dic = new Dictionary<char, int>();
              
        for(int r = 0; r < s.Length; r++)
        {
            char c = s[r];
            if(dic.ContainsKey(c))
            {
              l = Math.Max(dic[c] + 1 , l);
            } 
            dic[c] = r;
            maxLen = Math.Max(maxLen, r - l + 1);           
        }
        return maxLen;
